# ===================================================================
# COCO Vision Metrology — 環境設定範例
# ===================================================================
#
# 複製此文件為 .env，根據環境需要修改配置
# 在 Docker 中，可通過 docker run -e KEY=VALUE 覆蓋這些變數
#
# ===================================================================

# ---------------------------------------------------------------------------
# FastAPI / Uvicorn 設定
# ---------------------------------------------------------------------------

# 日誌級別: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# API 監聽地址
API_HOST=0.0.0.0

# API 監聽端口
API_PORT=8000

# Uvicorn workers 數量（生產模式）
# 建議: CPU bound tasks (inference) = 1-2
API_WORKERS=2

# 是否啟用自動重載（開發模式）
API_RELOAD=false

# ---------------------------------------------------------------------------
# 模型 & 推理設定
# ---------------------------------------------------------------------------

# 推理設備: cpu, cuda, mps (macOS Metal)
INFERENCE_DEVICE=cpu

# Mask R-CNN 信心分數閾值 [0, 1]
# 更高的值 → 更少偵測但準確度高
MASKRCNN_SCORE_THRESHOLD=0.7

# 關鍵點 (HRNet) 置信度閾值 [0, 1]
# 更高的值 → 只在確定時返回眼睛座標
KPT_SCORE_THRESHOLD=0.3

# SAM 分割置信度閾值 [0, 1]
SAM_SCORE_THRESHOLD=0.75

# 最小邊界框面積（像素²），用於過濾太小的動物
MIN_BBOX_AREA=3000

# ---------------------------------------------------------------------------
# 數據設定
# ---------------------------------------------------------------------------

# 允許的最大上傳檔案大小（MB）
MAX_UPLOAD_SIZE=50

# 支持的圖片格式（逗號分隔）
SUPPORTED_FORMATS=image/jpeg,image/png,image/webp

# ---------------------------------------------------------------------------
# 模型下載設定
# ---------------------------------------------------------------------------

# 模型下載超時時間（秒）
MODEL_DOWNLOAD_TIMEOUT=300

# 模型目錄路徑（相對於項目根目錄）
MODEL_DIR=app/models

# 是否跳過模型檢查並直接加載
SKIP_MODEL_VALIDATION=false

# ---------------------------------------------------------------------------
# 輸出與可視化設定
# ---------------------------------------------------------------------------

# 是否保存中間過程的可視化結果（用於除錯）
SAVE_VISUALIZATIONS=false

# 保存位置
VIS_OUTPUT_DIR=data/api_visualizations

# 是否在日誌中打印詳細的推理信息
VERBOSE_INFERENCE=false

# ---------------------------------------------------------------------------
# Docker 容器設定
# ---------------------------------------------------------------------------

# Python 環境變數：防止 stdout/stderr 緩衝
PYTHONUNBUFFERED=1

# ---------------------------------------------------------------------------
# 運行環境
# ---------------------------------------------------------------------------

# 環境類型: development, production
ENVIRONMENT=production

# 是否啟用 CORS（跨域請求）
ENABLE_CORS=true

# CORS 允許的源（逗號分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
